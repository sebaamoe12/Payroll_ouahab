# ─────────────────────────────────────────────────
# Database – pick ONE:
# ─────────────────────────────────────────────────

# Local PostgreSQL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/payroll_dev"

# Supabase (production) – also set on Vercel
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# ─────────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────────
NEXTAUTH_SECRET="generate with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
NEXTAUTH_URL="http://localhost:3000"

# On Vercel – also set:
# NEXTAUTH_URL="https://YOUR_VERCEL_DOMAIN.vercel.app"

# ─────────────────────────────────────────────────
# Supabase (optional – for admin / realtime / storage)
# ─────────────────────────────────────────────────
# These are set automatically by the Vercel + Supabase integration.
# For local dev, copy them from your Supabase project dashboard:
#   Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─────────────────────────────────────────────────
# Stripe – optional
# ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=""

# ─────────────────────────────────────────────────
# Resend – optional
# ─────────────────────────────────────────────────
RESEND_API_KEY=""
