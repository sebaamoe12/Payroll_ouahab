{
  "name": "payroll",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:seed": "dotenv -e .env -- prisma db seed",
